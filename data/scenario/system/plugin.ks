;タップエフェクト
[plugin name=tap_effect]
[tap_effect_start]
[tap_effect_set type="ripple" figure="circle" ratio="1/1" border_color="0xFFE2BE" border_width="1" bg_none="true" bg_color="white" pos_start="30" pos_end="80" duration="200" delete_delay="-100" delete_time="100" delete_type="fade"]
[tap_effect_set type="ripple" figure="circle" ratio="1/1" border_color="0x6DB7AB" border_width="1" bg_none="true" bg_color="0x6DB7AB" pos_start="5" pos_end="30" duration="300" delete_delay="-100" delete_time="200" delete_type="fade"]
[tap_effect_set type="particle" figure="twinkle" ratio="1/1" border_color="transparent" border_width="0" bg_none="false" bg_color="0xCB6DAF" pos_start="50" pos_end="100" count_min="2" count_max="4" size_min="15" size_max="20" duration="1200" delete_delay="-500" delete_time="500" delete_type="fade"]
;waapiのマスター音量設定
[lbgmmaster vol="&TYRANO.kag.config.defaultBgmVolume" buf="0"]
[lsemaster vol="&TYRANO.kag.config.defaultSeVolume" buf="1"]
;ループタグ付きBGMロード
[loadse str="1_debirun_failure_jingle.ogg"]
[loadse str="kioku.ogg"]
[loadbgm str="3_connection_communication.ogg"]
[loadbgm str="10_time_for_a_decisive_battle.ogg"]
[loadbgm str="neodebi.ogg"]
[loadbgm str="15_happy_wedding.ogg"]
;シームレスループさせるムービーロード
[load_bg_loop storage="haikei_u.mp4"]
[load_bg_loop storage="haikei_u2.mp4"]
[load_bg_loop storage="kyosyoku.mp4"]
[load_bg_loop storage="gekizyo.mp4"]
[load_bg_loop storage="gekizyo2.mp4"]
[load_bg_loop storage="kupya3.mp4"]
[load_bg_loop storage="taida.mp4"]

;APNGロード
[call storage="system/apng.ks"]
[load_title_loop]
[lwaitload]

;テストデータ
[eval exp="f.name='召唤师'"]
[eval exp="f.seibetu=1"]
[if exp="!f.finished"]
[eval exp="f.finished=[]"]
[eval exp="TYRANO.kag.tmp.escInTitle=false"]
[endif]

[loadjs storage="ending.js"]
[loadjs storage="collection.js"]
[loadjs storage="sticker.js"]
[loadjs storage="omake.js"]

;初期変数を格納する
[eval exp="sf.initialVars=f"]
[free layer=0 name="loading"]
[iscript]
const bg = sf.kill == 0 ? 'bg.png' : 'bg_fanatic.png'
$('body').css({
  'background-image': `url(./tyrano/images/system/${bg})`,
  'background-size': sf.kill == 0 ? 'auto' : 'cover',
})
$('.body_bg').css('opacity', 0)
[endscript]
[return] 